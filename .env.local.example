# Copia este ficheiro para ".env.local" (na raiz do projeto) e preenche
# com os valores reais do teu projeto Supabase.
#
# Onde encontrar estes valores:
# Supabase Dashboard -> Project Settings (ícone de engrenagem) -> API
#
# O ficheiro ".env.local" NUNCA deve ser enviado para o GitHub
# (já está protegido no .gitignore).

NEXT_PUBLIC_SUPABASE_URL=cola_aqui_o_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=cola_aqui_a_anon_public_key
